rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin check: requires custom claim set via Firebase Admin SDK
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // SMS queue: authenticated users can create, admins have full access.
    match /sms_queue/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null
                  && resource.data.callerUid == request.auth.uid;
      allow read, write: if isAdmin();
    }

    // Templates: authenticated users can read, admins can write.
    match /sms_templates/{templateId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Logs: admin read only. Admin SDK writes (server-side).
    match /sms_logs/{logId} {
      allow read: if isAdmin();
    }

    // OTP codes: no client access. Admin SDK only.
    match /otp_codes/{otpId} {
      allow read, write: if false;
    }

    // Extension config: admin read/write for dashboard.
    match /sms_config/{docId} {
      allow read, write: if isAdmin();
    }

    // Rate limit docs: no client access. Admin SDK only.
    match /sms_rate_limits/{docId} {
      allow read, write: if false;
    }
  }
}
