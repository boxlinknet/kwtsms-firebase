rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // SMS queue: authenticated users can create documents to send SMS.
    // Only the original caller can read their own documents.
    match /sms_queue/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null
                  && resource.data.callerUid == request.auth.uid;
    }

    // Templates: authenticated users can read (for client-side rendering).
    match /sms_templates/{templateId} {
      allow read: if request.auth != null;
    }

    // Logs: no client access. Admin SDK only.
    match /sms_logs/{logId} {
      allow read, write: if false;
    }

    // OTP codes: no client access. Admin SDK only.
    match /otp_codes/{otpId} {
      allow read, write: if false;
    }

    // Extension config (settings, sync, rate limits): no client access.
    match /sms_config/{docId} {
      allow read, write: if false;
    }

    // Rate limit docs: no client access. Admin SDK only.
    match /sms_rate_limits/{docId} {
      allow read, write: if false;
    }
  }
}
