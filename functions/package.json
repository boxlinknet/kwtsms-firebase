{
  "name": "kwtsms-firebase-extension",
  "version": "1.0.0",
  "description": "kwtSMS Firebase Extension - Send SMS via kwtSMS gateway from Firebase",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "firebase emulators:exec --only firestore 'npx tsx --test tests/**/*.test.ts'",
    "lint": "eslint src/",
    "clean": "rm -rf lib/"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "kwtsms": "^0.5.2"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.0.0",
    "firebase-tools": "^13.0.0"
  },
  "private": true
}
